# Optional, opt-in anonymous page-view analytics (self-hosted Umami).
#
# Analytics is OFF unless BOTH values below are set. Leave them empty (or skip
# this file entirely) and the build makes zero analytics requests — the default
# for the open-source build and local dev.
#
# To enable on a deployment, copy this file to `.env.local` (gitignored, never
# committed) and fill in the real values. Umami counts page views only — it
# never receives the user's paste, which never leaves the tab.

VITE_UMAMI_SRC=
VITE_UMAMI_WEBSITE_ID=
